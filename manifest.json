{
    "manifest_version":3,
    "name": "BSLA chrome extension",
    "version": "0.0.1",
    "description": "Initial version of the BSLA chrome extension",
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "action": {
        "default_popup": "src/popup/popup.html",
        "default_icon": {
            "16": "src/images/bsla16x16.png",
            "48": "src/images/bsla48x48.png",
            "128": "src/images/bsla128x128.png"
        },
        "default_title": "BSLA chrome extension"
    }
}